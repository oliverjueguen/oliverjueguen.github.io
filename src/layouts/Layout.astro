---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Oliver Jueguen | Ciberseguridad para pymes en A Coruña',
  description = 'Auditorías de ciberseguridad y consultoría especializada para pymes en A Coruña y Galicia. Protege tu negocio frente a amenazas digitales.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-neutral-950 text-neutral-100 antialiased">
    <slot />
  </body>
</html>
