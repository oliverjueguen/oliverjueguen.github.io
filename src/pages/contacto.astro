---
import Layout from '../layouts/Layout.astro';

const contactApiUrl =
  import.meta.env.PUBLIC_CONTACT_API_URL || 'https://contact-api.oliverjueguen.workers.dev';
const enviado = Astro.url.searchParams.get('enviado') === '1';
const cooldownSeconds = 120;
---

<Layout
  title="Contacto | Oliver Jueguen"
  description="Formulario de contacto para solicitar una auditoría de ciberseguridad a Oliver Jueguen."
>
  <main class="min-h-screen bg-[#0a0a0a] text-[#f5f1e8]">
    <section class="border-b border-white/10 bg-[radial-gradient(circle_at_top_left,_rgba(247,148,29,0.12),_transparent_28%),linear-gradient(180deg,_#0a0a0a_0%,_#111111_100%)]">
      <div class="mx-auto max-w-7xl px-6 pb-16 pt-6 md:px-10 md:pb-20">
        <header class="flex flex-col gap-6 border-b border-white/10 pb-6 md:flex-row md:items-center md:justify-between">
          <a href="/" class="text-sm font-semibold uppercase tracking-[0.28em] text-white">
            oliverjueguen.net
          </a>
          <nav class="flex flex-wrap items-center gap-2 text-sm uppercase tracking-[0.18em] text-neutral-300">
            <a href="/#servicios" class="rounded-full px-4 py-2 transition hover:bg-white/10 hover:text-white">
              Servicios
            </a>
            <a href="/#portfolio" class="rounded-full px-4 py-2 transition hover:bg-white/10 hover:text-white">
              Portfolio
            </a>
            <a href="/contacto" class="rounded-full px-4 py-2 text-white">
              Contacto
            </a>
          </nav>
        </header>

        <div class="grid gap-12 pt-14 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:pt-20">
          <div>
            <p class="text-sm uppercase tracking-[0.28em] text-[#f79a2d]">Contacto</p>
            <h1 class="mt-6 text-[3.1rem] leading-[0.94] font-semibold tracking-[-0.04em] text-white md:text-[5.25rem]">
              Solicita tu auditoría.
            </h1>
            <p class="mt-8 max-w-xl text-lg leading-8 text-neutral-300">
              Explícame tu caso y te contactaré para ver cómo puedo ayudarte.
            </p>
          </div>

          <div class="rounded-[2rem] border border-white/10 bg-white/[0.04] p-8">
            {enviado && (
              <div class="mb-6 rounded-2xl border border-emerald-400/30 bg-emerald-400/10 px-4 py-4 text-sm leading-7 text-emerald-100">
                Tu mensaje se ha enviado correctamente. Te responderé por correo lo antes posible.
              </div>
            )}
            <div
              id="contact-status-message"
              class="mb-6 hidden rounded-2xl border px-4 py-4 text-sm leading-7"
            ></div>
            <div
              id="contact-cooldown-message"
              class="mb-6 hidden rounded-2xl border border-amber-400/30 bg-amber-400/10 px-4 py-4 text-sm leading-7 text-amber-100"
            ></div>
            <form
              method="POST"
              class="grid gap-5"
              data-contact-form
              data-cooldown={cooldownSeconds}
              data-api-url={contactApiUrl}
            >
              <input
                type="checkbox"
                name="botcheck"
                tabindex="-1"
                autocomplete="off"
                class="pointer-events-none absolute left-[-9999px] opacity-0"
              />

              <div class="grid gap-2">
                <label for="nombre" class="text-sm font-medium text-neutral-200">Nombre</label>
                <input
                  id="nombre"
                  name="name"
                  type="text"
                  required
                  maxlength="120"
                  autocomplete="name"
                  class="rounded-2xl border border-white/10 bg-black/30 px-4 py-4 text-white outline-none transition placeholder:text-neutral-500 focus:border-[#f79a2d]"
                  placeholder="Tu nombre"
                />
              </div>

              <div class="grid gap-2">
                <label for="empresa" class="text-sm font-medium text-neutral-200">Empresa</label>
                <input
                  id="empresa"
                  name="empresa"
                  type="text"
                  maxlength="160"
                  autocomplete="organization"
                  class="rounded-2xl border border-white/10 bg-black/30 px-4 py-4 text-white outline-none transition placeholder:text-neutral-500 focus:border-[#f79a2d]"
                  placeholder="Nombre de tu empresa"
                />
              </div>

              <div class="grid gap-2 md:grid-cols-2 md:gap-4">
                <div class="grid gap-2">
                  <label for="email" class="text-sm font-medium text-neutral-200">Email</label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    required
                    autocomplete="email"
                    class="rounded-2xl border border-white/10 bg-black/30 px-4 py-4 text-white outline-none transition placeholder:text-neutral-500 focus:border-[#f79a2d]"
                    placeholder="tu@email.com"
                  />
                </div>

                <div class="grid gap-2">
                  <label for="telefono" class="text-sm font-medium text-neutral-200">Teléfono</label>
                  <input
                    id="telefono"
                    name="telefono"
                    type="tel"
                    inputmode="numeric"
                    pattern="[0-9]+"
                    maxlength="20"
                    autocomplete="tel"
                    class="rounded-2xl border border-white/10 bg-black/30 px-4 py-4 text-white outline-none transition placeholder:text-neutral-500 focus:border-[#f79a2d]"
                    placeholder="Tu teléfono"
                    oninput="this.value=this.value.replace(/[^0-9]/g,'')"
                  />
                </div>
              </div>

              <fieldset class="grid gap-3">
                <legend class="text-sm font-medium text-neutral-200">Vía preferida de contacto</legend>
                <div class="flex flex-col gap-3 sm:flex-row">
                  <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-black/30 px-4 py-4 text-white transition hover:border-[#f79a2d]">
                    <input
                      type="radio"
                      name="via_preferida"
                      value="Correo electrónico"
                      checked
                      class="h-4 w-4 accent-[#f79a2d]"
                    />
                    <span>Correo electrónico</span>
                  </label>
                  <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-black/30 px-4 py-4 text-white transition hover:border-[#f79a2d]">
                    <input
                      type="radio"
                      name="via_preferida"
                      value="Llamada telefónica"
                      class="h-4 w-4 accent-[#f79a2d]"
                    />
                    <span>Llamada telefónica</span>
                  </label>
                </div>
              </fieldset>

              <div class="grid gap-2">
                <label for="servicio" class="text-sm font-medium text-neutral-200">Servicio</label>
                <select
                  id="servicio"
                  name="servicio"
                  class="rounded-2xl border border-white/10 bg-black/30 px-4 py-4 text-white outline-none transition focus:border-[#f79a2d]"
                >
                  <option>Reconocimiento pasivo</option>
                  <option>Validación activa</option>
                  <option>Simulación ofensiva ampliada</option>
                  <option>Quiero que me asesores</option>
                </select>
              </div>

              <div class="grid gap-2">
                <label for="mensaje" class="text-sm font-medium text-neutral-200">Mensaje</label>
                <textarea
                  id="mensaje"
                  name="message"
                  required
                  rows="6"
                  maxlength="5000"
                  class="rounded-2xl border border-white/10 bg-black/30 px-4 py-4 text-white outline-none transition placeholder:text-neutral-500 focus:border-[#f79a2d]"
                  placeholder="Cuéntame tu caso, qué activos quieres revisar o qué te preocupa."
                ></textarea>
              </div>

              <button
                type="submit"
                data-submit-button
                class="mt-2 inline-flex items-center justify-center rounded-full bg-[#f5f1e8] px-7 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-black transition hover:bg-white"
              >
                Enviar solicitud
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  const form = document.querySelector('[data-contact-form]');
  const button = document.querySelector('[data-submit-button]');
  const message = document.getElementById('contact-cooldown-message');
  const statusMessage = document.getElementById('contact-status-message');

  if (form && button && message && statusMessage) {
    const storageKey = 'contact-form-last-submit';
    const cooldownSeconds = Number(form.getAttribute('data-cooldown') || '120');
    const apiUrl = form.getAttribute('data-api-url');

    const showStatus = (text, type) => {
      const styles = {
        success: 'border-emerald-400/30 bg-emerald-400/10 text-emerald-100',
        error: 'border-red-400/30 bg-red-400/10 text-red-100',
      };

      statusMessage.textContent = text;
      statusMessage.className = `mb-6 rounded-2xl border px-4 py-4 text-sm leading-7 ${styles[type]}`;
      statusMessage.classList.remove('hidden');
    };

    const renderCooldown = () => {
      const lastSubmit = Number(localStorage.getItem(storageKey) || '0');
      const now = Math.floor(Date.now() / 1000);
      const remaining = lastSubmit + cooldownSeconds - now;

      if (remaining > 0) {
        button.setAttribute('disabled', 'disabled');
        button.classList.add('cursor-not-allowed', 'opacity-60');
        message.textContent = `Espera ${remaining} segundos antes de enviar otro mensaje.`;
        message.classList.remove('hidden');
      } else {
        button.removeAttribute('disabled');
        button.classList.remove('cursor-not-allowed', 'opacity-60');
        message.textContent = '';
        message.classList.add('hidden');
      }
    };

    renderCooldown();
    window.setInterval(renderCooldown, 1000);

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const lastSubmit = Number(localStorage.getItem(storageKey) || '0');
      const now = Math.floor(Date.now() / 1000);

      if (lastSubmit + cooldownSeconds > now) {
        renderCooldown();
        return;
      }

      if (!apiUrl) {
        showStatus('Falta configurar el endpoint del formulario.', 'error');
        return;
      }

      localStorage.setItem(storageKey, String(now));
      button.setAttribute('disabled', 'disabled');
      button.classList.add('cursor-not-allowed', 'opacity-60');
      statusMessage.classList.add('hidden');

      fetch(apiUrl, {
        method: 'POST',
        body: new FormData(form),
        headers: {
          Accept: 'application/json',
        },
      })
        .then(async (response) => {
          const data = await response.json().catch(() => ({}));

          if (!response.ok || !data.success) {
            throw new Error(data.error || 'No se pudo enviar el formulario.');
          }

          window.location.href = '/contacto?enviado=1';
        })
        .catch((error) => {
          localStorage.removeItem(storageKey);
          button.removeAttribute('disabled');
          button.classList.remove('cursor-not-allowed', 'opacity-60');
          renderCooldown();
          showStatus(error.message || 'No se pudo enviar el formulario.', 'error');
        });
    });
  }
</script>
